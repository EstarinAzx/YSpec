{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "`", "close": "`" }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "`", "close": "`" }
  ],
  "folding": {
    "offSide": true,
    "markers": {
      "start": "^\\s*(function|class|module|const|let)\\s+\\w+:",
      "end": "^\\s*$"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(if|elseif|elif|else|while|for|try|catch|finally|logic|methods|fields|classes|functions|inputs|function\\s+\\w+|class\\s+\\w+).*:\\s*(\\|)?\\s*$",
    "decreaseIndentPattern": "^\\s*(elseif|elif|else|catch|finally)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*logic:\\s*\\|\\s*$",
      "action": { "indent": "indent" }
    },
    {
      "beforeText": "^\\s*(function|class)\\s+\\w+:\\s*$",
      "action": { "indent": "indent" }
    }
  ],
  "wordPattern": "[a-zA-Z_$][a-zA-Z0-9_$]*"
}
