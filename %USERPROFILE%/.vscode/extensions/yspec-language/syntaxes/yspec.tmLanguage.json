{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "YSpec",
  "scopeName": "source.yspec",
  "patterns": [
    { "include": "#comment" },
    { "include": "#structure-keys" },
    { "include": "#logic-block-start" },
    { "include": "#control-flow" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#function-calls" },
    { "include": "#variables" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.hash.yspec",
          "match": "#.*$"
        }
      ]
    },

    "structure-keys": {
      "patterns": [
        {
          "comment": "Top-level document kind",
          "match": "^(module|function|class|macro)(:)\\s*(.+)$",
          "captures": {
            "1": { "name": "keyword.control.document.yspec" },
            "2": { "name": "punctuation.separator.key-value.yspec" },
            "3": { "name": "entity.name.type.yspec" }
          }
        },
        {
          "comment": "Structure section keys (fields, methods, classes, etc)",
          "match": "^(\\s*)(functions|classes|methods|fields|inputs|exports|imports|variables|macros|logic)(:)",
          "captures": {
            "2": { "name": "keyword.other.section.yspec" },
            "3": { "name": "punctuation.separator.key-value.yspec" }
          }
        },
        {
          "comment": "const: and let: top-level variable sections",
          "match": "^(const|let)(:)\\s*$",
          "captures": {
            "1": { "name": "storage.type.yspec" },
            "2": { "name": "punctuation.separator.key-value.yspec" }
          }
        },
        {
          "comment": "Function/method definition",
          "match": "(- )(function)(:)\\s*(\\w+)",
          "captures": {
            "1": { "name": "punctuation.definition.list.yspec" },
            "2": { "name": "keyword.other.function-def.yspec" },
            "3": { "name": "punctuation.separator.key-value.yspec" },
            "4": { "name": "entity.name.function.yspec" }
          }
        },
        {
          "comment": "Class definition",
          "match": "(- )(class)(:)\\s*(\\w+)",
          "captures": {
            "1": { "name": "punctuation.definition.list.yspec" },
            "2": { "name": "keyword.other.class-def.yspec" },
            "3": { "name": "punctuation.separator.key-value.yspec" },
            "4": { "name": "entity.name.class.yspec" }
          }
        },
        {
          "comment": "Function metadata keys",
          "match": "^(\\s*)(async|returns|extends)(:)",
          "captures": {
            "2": { "name": "keyword.other.modifier.yspec" },
            "3": { "name": "punctuation.separator.key-value.yspec" }
          }
        }
      ]
    },

    "logic-block-start": {
      "patterns": [
        {
          "comment": "logic: | pipe block indicator",
          "match": "(logic)(:)\\s*(\\|)\\s*$",
          "captures": {
            "1": { "name": "keyword.other.section.yspec" },
            "2": { "name": "punctuation.separator.key-value.yspec" },
            "3": { "name": "punctuation.definition.block.pipe.yspec" }
          }
        }
      ]
    },

    "control-flow": {
      "patterns": [
        {
          "comment": "if condition:",
          "match": "\\b(if)\\s+(.+?)(:)\\s*$",
          "captures": {
            "1": { "name": "keyword.control.conditional.yspec" },
            "2": { "patterns": [{ "include": "#expression-inner" }] },
            "3": { "name": "punctuation.definition.block.yspec" }
          }
        },
        {
          "comment": "elseif condition:",
          "match": "\\b(elseif)\\s+(.+?)(:)\\s*$",
          "captures": {
            "1": { "name": "keyword.control.conditional.yspec" },
            "2": { "patterns": [{ "include": "#expression-inner" }] },
            "3": { "name": "punctuation.definition.block.yspec" }
          }
        },
        {
          "comment": "else:",
          "match": "\\b(else)(:)\\s*$",
          "captures": {
            "1": { "name": "keyword.control.conditional.yspec" },
            "2": { "name": "punctuation.definition.block.yspec" }
          }
        },
        {
          "comment": "while condition:",
          "match": "\\b(while)\\s+(.+?)(:)\\s*$",
          "captures": {
            "1": { "name": "keyword.control.loop.yspec" },
            "2": { "patterns": [{ "include": "#expression-inner" }] },
            "3": { "name": "punctuation.definition.block.yspec" }
          }
        },
        {
          "comment": "for item in collection:",
          "match": "\\b(for)\\s+(\\w+)\\s+(in)\\s+(.+?)(:)\\s*$",
          "captures": {
            "1": { "name": "keyword.control.loop.yspec" },
            "2": { "name": "variable.other.iterator.yspec" },
            "3": { "name": "keyword.operator.in.yspec" },
            "4": { "patterns": [{ "include": "#expression-inner" }] },
            "5": { "name": "punctuation.definition.block.yspec" }
          }
        },
        {
          "comment": "for var from start to end:",
          "match": "\\b(for)\\s+(\\w+)\\s+(from)\\s+(.+?)\\s+(to)\\s+(.+?)(:)\\s*$",
          "captures": {
            "1": { "name": "keyword.control.loop.yspec" },
            "2": { "name": "variable.other.iterator.yspec" },
            "3": { "name": "keyword.operator.range.yspec" },
            "4": { "patterns": [{ "include": "#expression-inner" }] },
            "5": { "name": "keyword.operator.range.yspec" },
            "6": { "patterns": [{ "include": "#expression-inner" }] },
            "7": { "name": "punctuation.definition.block.yspec" }
          }
        },
        {
          "comment": "try:",
          "match": "\\b(try)(:)\\s*$",
          "captures": {
            "1": { "name": "keyword.control.trycatch.yspec" },
            "2": { "name": "punctuation.definition.block.yspec" }
          }
        },
        {
          "comment": "catch Type as name:",
          "match": "\\b(catch)\\s+(\\w+)(?:\\s+(as)\\s+(\\w+))?(:)\\s*$",
          "captures": {
            "1": { "name": "keyword.control.trycatch.yspec" },
            "2": { "name": "entity.name.type.yspec" },
            "3": { "name": "keyword.operator.as.yspec" },
            "4": { "name": "variable.other.catch-binding.yspec" },
            "5": { "name": "punctuation.definition.block.yspec" }
          }
        },
        {
          "comment": "finally:",
          "match": "\\b(finally)(:)\\s*$",
          "captures": {
            "1": { "name": "keyword.control.trycatch.yspec" },
            "2": { "name": "punctuation.definition.block.yspec" }
          }
        }
      ]
    },

    "declarations": {
      "patterns": [
        {
          "comment": "const/let variable declaration",
          "match": "\\b(const|let)\\s+([a-zA-Z_${}\\[\\], ]+)\\s*(=)",
          "captures": {
            "1": { "name": "storage.type.yspec" },
            "2": { "name": "variable.other.declaration.yspec" },
            "3": { "name": "keyword.operator.assignment.yspec" }
          }
        },
        {
          "comment": "return statement",
          "match": "\\b(return)\\b",
          "name": "keyword.control.return.yspec"
        },
        {
          "comment": "raise/throw",
          "match": "\\b(raise)\\s+(\\w+)",
          "captures": {
            "1": { "name": "keyword.control.throw.yspec" },
            "2": { "name": "entity.name.type.yspec" }
          }
        },
        {
          "comment": "await",
          "match": "\\b(await)\\b",
          "name": "keyword.control.await.yspec"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "match": "\\b(new|typeof|instanceof|this|async|delete|void|yield)\\b",
          "name": "keyword.other.yspec"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.language.boolean.yspec"
        },
        {
          "match": "\\b(null|undefined)\\b",
          "name": "constant.language.null.yspec"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.backtick.yspec",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "meta.template.expression.yspec",
              "begin": "\\$\\{",
              "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.yspec" } },
              "end": "\\}",
              "endCaptures": { "0": { "name": "punctuation.definition.template-expression.end.yspec" } },
              "patterns": [{ "include": "#expression-inner" }]
            }
          ]
        },
        {
          "name": "string.quoted.double.yspec",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.yspec", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.yspec",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.yspec", "match": "\\\\." }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "match": "\\b(0x[0-9a-fA-F]+|0o[0-7]+|0b[01]+|\\d+\\.?\\d*([eE][+-]?\\d+)?)\\b",
          "name": "constant.numeric.yspec"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "match": "(===|!==|==|!=|>=|<=|=>|&&|\\|\\||\\+\\+|--|\\+=|-=|\\*=|/=)",
          "name": "keyword.operator.yspec"
        },
        {
          "match": "(=)",
          "name": "keyword.operator.assignment.yspec"
        },
        {
          "match": "(!|>|<|\\+|-|\\*|/|%)",
          "name": "keyword.operator.arithmetic.yspec"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "comment": "Type annotations in fields/inputs",
          "match": "\\b(string|number|boolean|object|any|void|Function|Array|Promise)\\b",
          "name": "support.type.yspec"
        },
        {
          "comment": "Array types like string[] or object[]",
          "match": "\\b(\\w+)(\\[\\])",
          "captures": {
            "1": { "name": "support.type.yspec" },
            "2": { "name": "support.type.array-suffix.yspec" }
          }
        }
      ]
    },

    "function-calls": {
      "patterns": [
        {
          "comment": "Method/function calls",
          "match": "\\b([a-zA-Z_$][a-zA-Z0-9_$.]*)(\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.yspec" },
            "2": { "name": "punctuation.definition.arguments.begin.yspec" }
          }
        }
      ]
    },

    "variables": {
      "patterns": [
        {
          "comment": "this keyword",
          "match": "\\b(this)\\b",
          "name": "variable.language.this.yspec"
        },
        {
          "comment": "SCREAMING_CASE constants",
          "match": "\\b([A-Z][A-Z0-9_]+)\\b",
          "name": "variable.other.constant.yspec"
        }
      ]
    },

    "expression-inner": {
      "patterns": [
        { "include": "#constants" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#keywords" },
        { "include": "#function-calls" },
        { "include": "#variables" }
      ]
    }
  }
}
